# ===========================================
# CẤU HÌNH KẾT NỐI DATABASE PHÂN TÁN
# Copy file này thành .env và điền thông tin máy của bạn
# Kiến trúc: 1 SQL Server local (port 1433) mở 4 Database
# ===========================================

# --- MIỀN NAM (HCM) - PRIMARY ---
DB_NAM_PRIMARY_SERVER=localhost
DB_NAM_PRIMARY_PORT=1433
DB_NAM_PRIMARY_DATABASE=RideApp_Nam
DB_NAM_PRIMARY_USER=sa
DB_NAM_PRIMARY_PASSWORD=123456

# --- MIỀN NAM (HCM) - REPLICA (Read-Only) ---
DB_NAM_REPLICA_SERVER=localhost
DB_NAM_REPLICA_PORT=1433
DB_NAM_REPLICA_DATABASE=RideApp_Nam_Replica
DB_NAM_REPLICA_USER=sa
DB_NAM_REPLICA_PASSWORD=123456

# --- MIỀN BẮC (HN) - PRIMARY ---
DB_BAC_PRIMARY_SERVER=localhost
DB_BAC_PRIMARY_PORT=1433
DB_BAC_PRIMARY_DATABASE=RideApp_Bac
DB_BAC_PRIMARY_USER=sa
DB_BAC_PRIMARY_PASSWORD=123456

# --- MIỀN BẮC (HN) - REPLICA (Read-Only) ---
DB_BAC_REPLICA_SERVER=localhost
DB_BAC_REPLICA_PORT=1433
DB_BAC_REPLICA_DATABASE=RideApp_Bac_Replica
DB_BAC_REPLICA_USER=sa
DB_BAC_REPLICA_PASSWORD=123456

# --- CẤU HÌNH SERVER ---
JWT_SECRET=ride_app_secret_key_nhom2_2026
